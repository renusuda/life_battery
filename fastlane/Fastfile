require "yaml"

platform :android do
  desc "Build and upload an Android internal release to Google Play internal track"
  lane :internal do
    ensure_required_env_vars!(android_release_env_vars)
    upload_android_release(track: "internal")
  end

  desc "Build and upload an Android production release to Google Play production track"
  lane :production do
    ensure_required_env_vars!(android_release_env_vars)
    upload_android_release(track: "production")
  end
end

platform :ios do
  desc "Build and upload an iOS release to TestFlight"
  lane :beta do
    setup_ci
    api_key = app_store_connect_api_key_for_release
    version = release_version

    prepare_ios_release_build(api_key: api_key, version: version)

    upload_to_testflight(
      api_key: api_key,
      ipa: built_ipa_path,
      changelog: ENV["FASTLANE_CHANGELOG"],
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build, wait for processing, and submit the iOS release for App Store review with automatic release after approval"
  lane :production do
    setup_ci
    api_key = app_store_connect_api_key_for_release
    version = release_version

    upload_production_build(api_key: api_key, version: version)
    wait_for_app_store_build(api_key: api_key, version: version)
    submit_production_build(api_key: api_key, version: version)
  end
end

def app_store_connect_api_key_for_release
  ensure_required_env_vars!(release_env_vars)

  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
    key_content: normalized_api_key_content,
    is_key_content_base64: api_key_base64?,
    duration: 1200,
    in_house: false,
  )
end

def primary_app_identifier
  "com.rururu.lifebt"
end

def ensure_required_env_vars!(keys)
  missing = keys.select { |key| ENV[key].to_s.empty? }
  return if missing.empty?

  UI.user_error!("Missing environment variables: #{missing.join(', ')}")
end

def env_flag(key, default: false)
  value = ENV[key]
  return default if value.nil?

  %w[1 true yes].include?(value.downcase)
end

def api_key_base64?
  true
end

def release_env_vars
  %w[
    APP_STORE_CONNECT_API_KEY_ID
    APP_STORE_CONNECT_API_ISSUER_ID
    APP_STORE_CONNECT_API_KEY_CONTENT
    MATCH_GIT_URL
    MATCH_PASSWORD
  ]
end

def android_release_env_vars
  %w[
    PLAY_SERVICE_ACCOUNT_JSON
  ]
end

def normalized_api_key_content
  content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT")
  return content if api_key_base64?

  content.gsub('\n', "\n")
end

def built_ipa_path
  ipa_dir = File.expand_path("../build/ios/ipa", __dir__)
  ipa = Dir["#{ipa_dir}/*.ipa"].first
  UI.user_error!("No IPA found in #{ipa_dir}") if ipa.nil?
  ipa
end

def release_version
  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  version = YAML.load_file(pubspec_path).fetch("version")
  build_name, build_number = version.split("+", 2)

  {
    build_name: build_name,
    build_number: build_number,
  }
end

def built_aab_path
  sh("flutter", "build", "appbundle", "--release")

  aab_path = File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)
  UI.user_error!("No AAB found in #{aab_path}") unless File.exist?(aab_path)

  aab_path
end

def upload_android_release(track:)
  upload_to_play_store(
    json_key_data: ENV.fetch("PLAY_SERVICE_ACCOUNT_JSON"),
    package_name: primary_app_identifier,
    aab: built_aab_path,
    track: track,
    version_name: android_version_name,
    metadata_path: android_metadata_path,
    skip_upload_images: true,
    skip_upload_screenshots: true,
  )
end

def android_version_name
  release_version.fetch(:build_name)
end

def android_metadata_path
  File.expand_path("metadata/android", __dir__)
end

def export_options_plist_path
  File.expand_path("../ios/ExportOptions.plist", __dir__)
end

def prepare_ios_release_build(api_key:, version:)
  match(
    type: "appstore",
    api_key: api_key,
    git_url: ENV.fetch("MATCH_GIT_URL"),
    app_identifier: match_app_identifiers,
    readonly: true,
  )

  sh(
    "flutter",
    "build",
    "ipa",
    "--release",
    "--export-options-plist=#{export_options_plist_path}",
    "--build-name",
    version.fetch(:build_name),
    "--build-number",
    version.fetch(:build_number),
  )
end

def upload_production_build(api_key:, version:)
  prepare_ios_release_build(api_key: api_key, version: version)

  upload_to_app_store(
    api_key: api_key,
    app_identifier: primary_app_identifier,
    ipa: built_ipa_path,
    app_version: version.fetch(:build_name),
    precheck_include_in_app_purchases: false,
    skip_metadata: false,
    skip_screenshots: true,
    skip_app_version_update: false,
    submit_for_review: false,
    force: true,
  )
end

def submit_production_build(api_key:, version:)
  upload_to_app_store(
    api_key: api_key,
    app_identifier: primary_app_identifier,
    app_version: version.fetch(:build_name),
    build_number: version.fetch(:build_number),
    skip_binary_upload: true,
    precheck_include_in_app_purchases: false,
    skip_metadata: true,
    skip_screenshots: true,
    submit_for_review: true,
    automatic_release: true,
    force: true,
    submission_information: app_store_submission_information,
  )
end

def match_app_identifiers
  [
    primary_app_identifier,
    "com.rururu.lifebt.LifeBatteryWidget",
  ]
end

def wait_for_app_store_build(api_key:, version:)
  app = Spaceship::ConnectAPI::App.find(primary_app_identifier)
  UI.user_error!("Could not find an app on App Store Connect with app_identifier: #{primary_app_identifier}") unless app

  FastlaneCore::BuildWatcher.wait_for_build_processing_to_be_complete(
    app_id: app.id,
    platform: "ios",
    app_version: version.fetch(:build_name),
    build_version: version.fetch(:build_number),
    poll_interval: 30,
    timeout_duration: 1800,
    return_when_build_appears: false,
    return_spaceship_testflight_build: false,
    select_latest: false,
  )

  UI.success(
    "Build #{version.fetch(:build_name)} (#{version.fetch(:build_number)}) finished processing in App Store Connect.",
  )
end

def app_store_submission_information
  {
    export_compliance_uses_encryption:
      false,
  }
end
