require "yaml"

default_platform(:ios)

platform :ios do
  desc "Build and upload an iOS release to TestFlight"
  lane :beta do
    ensure_required_env_vars!(
      %w[
        APP_STORE_CONNECT_API_KEY_ID
        APP_STORE_CONNECT_API_ISSUER_ID
        APP_STORE_CONNECT_API_KEY_CONTENT
        MATCH_GIT_URL
        MATCH_PASSWORD
      ],
    )

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content: normalized_api_key_content,
      is_key_content_base64: api_key_base64?,
      duration: 1200,
      in_house: false,
    )

    match(
      type: "appstore",
      api_key: api_key,
      git_url: ENV.fetch("MATCH_GIT_URL"),
      app_identifier: [
        "com.rururu.lifebt",
        "com.rururu.lifebt.LifeBatteryWidget",
      ],
      readonly: env_flag("MATCH_READONLY", default: false),
    )

    version = pubspec_version

    sh("fvm flutter pub get")
    sh(
      [
        "fvm flutter build ipa",
        "--release",
        "--export-method app-store",
        "--build-name #{version.fetch(:build_name)}",
        "--build-number #{version.fetch(:build_number)}",
      ].join(" "),
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: built_ipa_path,
      changelog: ENV["FASTLANE_CHANGELOG"],
      skip_waiting_for_build_processing: env_flag(
        "FASTLANE_SKIP_WAITING_FOR_BUILD_PROCESSING",
        default: true,
      ),
    )
  end
end

def ensure_required_env_vars!(keys)
  missing = keys.select { |key| ENV[key].to_s.empty? }
  return if missing.empty?

  UI.user_error!("Missing environment variables: #{missing.join(', ')}")
end

def env_flag(key, default: false)
  value = ENV[key]
  return default if value.nil?

  %w[1 true yes].include?(value.downcase)
end

def api_key_base64?
  env_flag("APP_STORE_CONNECT_API_KEY_IS_BASE64", default: false)
end

def normalized_api_key_content
  ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT")
end

def built_ipa_path
  ipa = Dir[File.expand_path("../build/ios/ipa/*.ipa", __dir__)].first
  UI.user_error!("No IPA found in build/ios/ipa") if ipa.nil?

  ipa
end

def pubspec_version
  pubspec_path = File.expand_path("../pubspec.yaml", __dir__)
  version = YAML.load_file(pubspec_path).fetch("version")
  build_name, build_number = version.split("+", 2)

  {
    build_name: build_name,
    build_number: build_number,
  }
end
